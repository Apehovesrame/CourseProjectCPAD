<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<AnchorPane prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.ReportsController">
    <VBox spacing="15" AnchorPane.bottomAnchor="15" AnchorPane.leftAnchor="15" AnchorPane.rightAnchor="15" AnchorPane.topAnchor="15">

        <Label text="%reports.title" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f0f0f0; -fx-padding: 10; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;">
            <Label text="%reports.period_from" />
            <DatePicker fx:id="dpStart" prefWidth="130"/>
            <Label text="%reports.period_to" />
            <DatePicker fx:id="dpEnd" prefWidth="130"/>
            <Button text="%reports.btn.generate" onAction="#handleGenerateReport" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="%reports.btn.export" onAction="#handleExportCsv" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <TableView fx:id="reportTable" prefWidth="400" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDestination" text="%reports.col.destination" prefWidth="180"/>
                    <TableColumn fx:id="colTickets" text="%reports.col.tickets" prefWidth="110"/>
                    <TableColumn fx:id="colRevenue" text="%reports.col.revenue" prefWidth="100"/>
                </columns>
            </TableView>

            <PieChart fx:id="pieChart" title="%reports.chart.title" prefWidth="350" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_RIGHT">
            <Label text="%reports.total_revenue" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <!-- Начальное значение 0.00, валюта будет подставляться из контроллера -->
            <Label fx:id="lblTotalRevenue" text="0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
        </HBox>

    </VBox>
</AnchorPane>