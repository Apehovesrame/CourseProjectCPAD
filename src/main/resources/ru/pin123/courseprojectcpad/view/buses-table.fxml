<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="515.0" prefWidth="649.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.BusController">
    <children>
        <VBox spacing="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
            <TableView fx:id="busTable" prefHeight="300.0" prefWidth="381.0">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="50" text="%col.id" />
                    <TableColumn fx:id="modelColumn" prefWidth="150" text="%col.model" />
                    <TableColumn fx:id="plateColumn" prefWidth="100" text="%col.plate" />
                    <TableColumn fx:id="capacityColumn" prefWidth="80" text="%col.capacity" />
                </columns>
            </TableView>
            <HBox spacing="10.0">
                <Button fx:id="addBusButton" onAction="#onAddBus" text="%btn.add" />
                <Button fx:id="editBusButton" onAction="#onEditBus" text="%btn.edit" />
                <Button fx:id="deleteBusButton" onAction="#onDeleteBus" text="%btn.delete" />
            </HBox>
        </VBox>
      <Pane layoutX="427.0" layoutY="78.0" prefHeight="200.0" prefWidth="200.0">
         <children>
            <ImageView fx:id="busImage" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </Pane>
    </children>
</AnchorPane>
