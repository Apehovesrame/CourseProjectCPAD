<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.pin123.courseprojectcpad.controller.UsersController">
    <VBox spacing="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colLogin" text="%users.col.login" prefWidth="120"/>
                <TableColumn fx:id="colLastName" text="%col.lastname" prefWidth="150"/>
                <TableColumn fx:id="colFirstName" text="%col.firstname" prefWidth="120"/>
                <TableColumn fx:id="colMiddleName" text="%col.middlename" prefWidth="150"/>
                <TableColumn fx:id="colRole" text="%users.col.role" prefWidth="100"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <Button text="%users.btn.add" onAction="#handleAdd" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button text="%btn.edit" onAction="#handleEdit" style="-fx-cursor: hand;"/>
            <Button text="%btn.delete" onAction="#handleDelete" style="-fx-text-fill: #D32F2F; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</AnchorPane>