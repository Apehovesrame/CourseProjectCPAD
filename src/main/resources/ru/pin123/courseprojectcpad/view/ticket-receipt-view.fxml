<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="450.0" prefWidth="350.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.TicketReceiptController">
    <VBox layoutX="20.0" layoutY="20.0" prefWidth="310.0" style="-fx-background-color: white; -fx-border-color: #333; -fx-border-width: 2; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);">

        <Label text="АВТОВОКЗАЛ МУРОМ" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-alignment: center;" prefWidth="270"/>
        <Label text="МАРШРУТНАЯ КВИТАНЦИЯ" style="-fx-font-size: 14px; -fx-alignment: center;" prefWidth="270"/>

        <Line endX="270" stroke="#333" strokeDashArray="5,5" style="-fx-translate-y: 10; -fx-margin-bottom: 20;"/>

        <GridPane vgap="12" hgap="10" style="-fx-translate-y: 20;">
            <columnConstraints>
                <ColumnConstraints prefWidth="100"/>
                <ColumnConstraints prefWidth="170"/>
            </columnConstraints>

            <Label text="Билет №:" GridPane.rowIndex="0" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblRegNumber" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>

            <Label text="Пассажир:" GridPane.rowIndex="1" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblPassenger" GridPane.rowIndex="1" GridPane.columnIndex="1" wrapText="true"/>

            <Label text="Маршрут:" GridPane.rowIndex="2" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblRoute" GridPane.rowIndex="2" GridPane.columnIndex="1" wrapText="true" style="-fx-font-weight: bold;"/>

            <Label text="Автобус:" GridPane.rowIndex="3" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblBus" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Место:" GridPane.rowIndex="4" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblSeat" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #D32F2F;"/>

            <Label text="Отправление:" GridPane.rowIndex="5" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblDeparture" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Дата продажи:" GridPane.rowIndex="6" style="-fx-text-fill: grey;"/>
            <Label fx:id="lblSaleDate" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="СТОИМОСТЬ:" GridPane.rowIndex="7" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblCost" GridPane.rowIndex="7" GridPane.columnIndex="1" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </GridPane>

        <Button text="Закрыть и распечатать" onAction="#handleClose" prefWidth="270" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-translate-y: 40; -fx-cursor: hand;"/>
    </VBox>
</AnchorPane>