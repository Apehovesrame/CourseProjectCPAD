<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.TicketSellController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox prefWidth="350.0" spacing="10.0">
        <Label text="%lbl.cashbox">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <ListView fx:id="tripsListView" prefHeight="600.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox prefHeight="641.0" prefWidth="593.0" spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">

        <Label text="%lbl.checkout" textFill="#333333">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <HBox prefHeight="379.0" prefWidth="608.0" spacing="30.0">
            <VBox prefHeight="241.0" prefWidth="353.0" spacing="15.0" HBox.hgrow="ALWAYS">

                <!-- НОВЫЙ БЛОК: Информация о маршруте -->
                <VBox spacing="5.0" style="-fx-background-color: #f8f9fa; -fx-padding: 12; -fx-background-radius: 6; -fx-border-color: #dee2e6; -fx-border-radius: 6;">
                    <Label text="Информация о маршруте" style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13px;" />
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Откуда:" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" />
                            <Label fx:id="lblDeparturePoint" text="—" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #212529;" />
                        </VBox>
                        <Label text="→" style="-fx-font-size: 20px; -fx-text-fill: #6c757d; -fx-padding: 16 0 0 0;" />
                        <VBox>
                            <Label text="Куда:" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" />
                            <Label fx:id="lblDestinationPoint" text="—" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #212529;" />
                        </VBox>
                    </HBox>
                    <HBox spacing="10.0" style="-fx-padding: 5 0 0 0;">
                        <Label text="Время в пути:" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" />
                        <Label fx:id="lblDuration" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0d6efd; -fx-font-size: 13px;" />
                    </HBox>
                </VBox>

                <Label text="%lbl.where" />
                <ComboBox fx:id="stopComboBox" maxWidth="Infinity" promptText="%combo.stop" style="-fx-background-color: #f0f0f0; -fx-border-color: #cccccc; -fx-border-radius: 4;" />

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="%lbl.price" textFill="#666666" />
                    <Label fx:id="costLabel" text="0.00" textFill="#4caf50">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                </HBox>

                <Label text="%lbl.passenger" />
                <TextField fx:id="fioField" prefHeight="39.0" prefWidth="395.0" promptText="%prompt.fio" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #ccc; -fx-border-radius: 4;" />
                <TextField fx:id="passportField" promptText="%prompt.passport" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #ccc; -fx-border-radius: 4;" />
                <TextField fx:id="birthYearField" promptText="Год рождения (напр. 1990)" style="-fx-padding: 10; -fx-background-radius: 4; -fx-border-color: #ccc; -fx-border-radius: 4;" />
            </VBox>

            <!-- ВМЕСТО СТАРОГО БЛОКА С КНОПКАМИ ТЕПЕРЬ ЭТОТ КОД: -->
            <VBox alignment="TOP_CENTER" prefHeight="379.0" prefWidth="258.0" spacing="10.0">
                <Label text="%lbl.seat" />

                <!-- ПАНЕЛЬ ПРОКРУТКИ -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="350.0" prefHeight="350.0" prefWidth="241.0" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED">

                    <GridPane fx:id="seatsGrid" alignment="CENTER" hgap="10.0" vgap="10.0">
                        <children>
                            <!-- Кнопки будут добавляться сюда динамически из Java-кода -->
                        </children>
                    </GridPane>

                </ScrollPane>
            </VBox>
        </HBox>

        <Button fx:id="sellButton" maxWidth="Infinity" onAction="#onSellTicketClick" prefHeight="50.0" styleClass="btn-warning" text="%btn.sell">
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
        </Button>
    </VBox>
</HBox>
