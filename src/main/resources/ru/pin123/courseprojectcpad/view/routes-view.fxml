<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.RoutesController">
    <VBox spacing="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <TableView fx:id="routeTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNumber" text="%routes.col.number" prefWidth="100"/>
                <TableColumn fx:id="colFrom" text="%routes.col.from" prefWidth="150"/>
                <TableColumn fx:id="colTo" text="%routes.col.to" prefWidth="150"/>
                <TableColumn fx:id="colDuration" text="%routes.col.duration" prefWidth="120"/>
            </columns>
        </TableView>

        <HBox spacing="10">
            <Button text="%routes.btn.add" onAction="#handleAdd" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button text="%btn.edit" onAction="#handleEdit" style="-fx-cursor: hand;"/>
            <Button text="%btn.delete" onAction="#handleDelete" style="-fx-text-fill: #D32F2F; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</AnchorPane>