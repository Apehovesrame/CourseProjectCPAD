<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane fx:id="mainBorderPane" prefWidth="1200.0" prefHeight="800.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.pin123.courseprojectcpad.controller.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 20; -fx-background-color: #e0e0e0; -fx-border-color: #ccc; -fx-border-width: 0 0 1 0;">
            <Label fx:id="lblGreeting" text="%menu.welcome" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="%login.lang" />
            <ComboBox fx:id="langSelector" onAction="#onLanguageChange" prefWidth="120.0" />
            <Button text="%menu.logout" onAction="#onLogoutClick" style="-fx-cursor: hand;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-border-color: #ccc; -fx-border-width: 0 1 0 0;" prefWidth="220.0">

            <Label text="%menu.category.management" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-font-weight: bold;"/>
            <Button fx:id="btnTicketSell" text="%menu.sell" onAction="#onTicketSellClick" prefWidth="190.0" prefHeight="35.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Button fx:id="btnTrips" text="%menu.trips" onAction="#onTripsClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>

            <Label text="%menu.category.analytics" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-font-weight: bold; -fx-padding: 15 0 0 0;"/>
            <Button fx:id="btnReports" text="%menu.reports" onAction="#onReportsClick" prefWidth="190.0" prefHeight="30.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>

            <Label text="%menu.category.admin" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-font-weight: bold; -fx-padding: 15 0 0 0;"/>
            <Button fx:id="btnUsers" text="%menu.users" onAction="#onUsersClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>

            <Label text="%menu.category.directories" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-font-weight: bold; -fx-padding: 15 0 0 0;"/>
            <Button fx:id="btnRoutes" text="%menu.routes" onAction="#onRoutesClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>
            <Button fx:id="btnBuses" text="%menu.buses" onAction="#onBusesClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>
            <Button fx:id="btnDrivers" text="%menu.drivers" onAction="#onDriversClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>
            <Button fx:id="btnPassengers" text="%menu.passengers" onAction="#onPassengersClick" prefWidth="190.0" prefHeight="30.0" style="-fx-cursor: hand;"/>
            <Button fx:id="btnAudit" text="%menu.audit" onAction="#onAuditClick" maxWidth="Infinity" styleClass="menu-btn"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 20;">
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="%menu.main_title" style="-fx-font-size: 32px; -fx-text-fill: #ccc; -fx-font-weight: bold;"/>
                <Label text="%menu.main_subtitle" style="-fx-font-size: 16px; -fx-text-fill: #aaa;"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>