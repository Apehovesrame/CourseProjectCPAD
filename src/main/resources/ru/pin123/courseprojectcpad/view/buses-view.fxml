<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="250.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.pin123.courseprojectcpad.controller.BusEditController">
    <children>
        <GridPane layoutX="20.0" layoutY="20.0" prefHeight="150.0" prefWidth="310.0" vgap="10" hgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="80.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="200.0" minWidth="10.0" prefWidth="180.0" />
            </columnConstraints>
            <children>
                <!-- Заменили текст на ключи -->
                <Label text="%col.model" GridPane.rowIndex="0" />
                <TextField fx:id="tfModel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="%col.plate" GridPane.rowIndex="1" />
                <TextField fx:id="tfLicensePlate" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="%col.capacity" GridPane.rowIndex="2" />
                <TextField fx:id="tfSeatCapacity" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>
        <HBox layoutX="170.0" layoutY="200.0" spacing="10.0">
            <children>
                <!-- Заменили текст на ключи -->
                <Button fx:id="btnSaveBus" onAction="#handleOk" text="%btn.ok" prefWidth="70" />
                <Button fx:id="btnCancelBus" onAction="#handleCancel" text="%btn.cancel" prefWidth="70" />
            </children>
        </HBox>
    </children>
</AnchorPane>